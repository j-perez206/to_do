{% extends 'base.html.twig' %}

{% block title %}{{ parent() }}{% endblock %}

{% block body %}

    <head>
        <meta charset="utf-8"/>
        <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
        <script id="tailwind-config">
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "on-tertiary-fixed": "#281901",
                            "secondary-container": "#dee2ee",
                            "surface-container-high": "#e6e8ea",
                            "on-primary": "#ffffff",
                            "on-primary-fixed-variant": "#003ea8",
                            "secondary-fixed": "#dee2ee",
                            "on-background": "#191c1e",
                            "surface-container-lowest": "#ffffff",
                            "on-tertiary-container": "#c3a881",
                            "tertiary": "#38270a",
                            "primary-fixed": "#dbe1ff",
                            "on-secondary-container": "#5f656e",
                            "secondary": "#595f68",
                            "on-error-container": "#93000a",
                            "inverse-on-surface": "#eff1f3",
                            "surface": "#f7f9fb",
                            "on-secondary-fixed": "#171c24",
                            "surface-bright": "#f7f9fb",
                            "outline": "#75777d",
                            "on-secondary": "#ffffff",
                            "surface-dim": "#d8dadc",
                            "primary": "#00246a",
                            "on-primary-fixed": "#00174b",
                            "primary-container": "#00389a",
                            "surface-tint": "#0053db",
                            "surface-variant": "#e0e3e5",
                            "error-container": "#ffdad6",
                            "outline-variant": "#c5c6cd",
                            "surface-container-highest": "#e0e3e5",
                            "background": "#f7f9fb",
                            "inverse-primary": "#b4c5ff",
                            "on-primary-container": "#8da9ff",
                            "inverse-surface": "#2d3133",
                            "surface-container-low": "#f2f4f6",
                            "on-surface": "#191c1e",
                            "on-tertiary-fixed-variant": "#574424",
                            "error": "#ba1a1a",
                            "on-secondary-fixed-variant": "#424750",
                            "on-tertiary": "#ffffff",
                            "on-surface-variant": "#44474c",
                            "surface-container": "#eceef0",
                            "tertiary-container": "#503d1e",
                            "on-error": "#ffffff",
                            "primary-fixed-dim": "#b4c5ff",
                            "tertiary-fixed": "#fcdeb3",
                            "secondary-fixed-dim": "#c2c6d1",
                            "tertiary-fixed-dim": "#dfc299"
                        },
                        fontFamily: {
                            "headline": ["Manrope"],
                            "body": ["Inter"],
                            "label": ["Inter"]
                        },
                        borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
                    },
                },
            }
        </script>
        <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
                display: inline-block;
                vertical-align: middle;
            }
            .editorial-gradient {
                background: linear-gradient(135deg, #00246a 0%, #00389a 100%);
            }
            .ambient-lift {
                box-shadow: 0 32px 64px -12px rgba(25, 28, 30, 0.06);
            }
        </style>
    </head>
    <body class="bg-surface font-body text-on-surface antialiased min-h-screen flex flex-col">
    <main class="flex-grow flex items-center justify-center pt-20 pb-12 px-6">
        <!-- Centered Layout Container -->
        <div class="w-full max-w-lg flex flex-col items-center text-center">
            <!-- Heading Composition -->
            <div class="mb-12">
                <h1 class="font-headline font-extrabold text-4xl md:text-5xl text-on-surface tracking-tight leading-tight mb-4">
                    To Do <br/>App.
                </h1>
            </div>
            <!-- Login Card -->
            <div class="w-full bg-surface-container-lowest ambient-lift p-10 relative text-left">
                <!-- Progress Line Indicator -->
                <div class="absolute top-0 left-0 w-full h-[2px] bg-primary-fixed">
                    <div class="h-full bg-primary w-1/3"></div>
                </div>

                {% if error %}
                    <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form class="space-y-8" action="{{ path('app_login') }}" method="post">
                    <!-- Email Field -->
                    <div class="space-y-2">
                        <label class="font-label text-xs font-semibold text-on-surface-variant uppercase tracking-widest" for="username">
                            Email
                        </label>
                        <input class="w-full bg-surface-container-low border-b-2 border-transparent border-b-outline-variant/20 focus:border-b-primary focus:ring-0 transition-all duration-300 px-0 py-4 font-body text-on-surface placeholder:text-outline-variant outline-none" id="username" type="text" name="_username" required/>
                    </div>
                    <!-- Password Field -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-end">
                            <label class="font-label text-xs font-semibold text-on-surface-variant uppercase tracking-widest" for="password">
                                Contraseña
                            </label>
                        </div>
                        <input class="w-full bg-surface-container-low border-b-2 border-transparent border-b-outline-variant/20 focus:border-b-primary focus:ring-0 transition-all duration-300 px-0 py-4 font-body text-on-surface placeholder:text-outline-variant outline-none" id="password" type="password" name="_password" required/>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="/">
                    <!-- Login Button -->
                    <div class="pt-4">
                        <button class="w-full editorial-gradient text-on-primary font-label font-bold uppercase tracking-widest py-5 rounded-md hover:opacity-90 transition-all active:scale-[0.98] shadow-lg shadow-primary/20" type="submit">
                            Iniciar sesión
                        </button>
                    </div>
                </form>
                <!-- Registration Link -->
                <div class="mt-12 text-center">
                    <p class="font-body text-sm text-on-surface-variant">
                        ¿No tienes cuenta?
                        <a class="font-bold text-primary hover:underline ml-1 underline-offset-4" href="{{ path('app_register') }}">Regístrate</a>
                    </p>
                </div>
            </div>
        </div>
    </main>
    </body>

{% endblock %}
