{% extends 'base.html.twig' %}

{% block title %}{{ parent() }}{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }

    {# Estilos del formulario #}
    .form-container {
        padding: 20px;
        margin-bottom: 20px;
    }

    .form-group { margin-bottom: 15px; }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
        color: #333;
    }

    .form-group.checkbox-group {
        display: flex;
        align-items: center;
    }

    .form-group.checkbox-group label {
        display: inline;
        margin-bottom: 0;
        font-weight: normal;
        margin-left: 0;
        margin-right: 8px;
    }

    .form-group textarea, .form-group input[type="checkbox"] {
        width: 100%;
        padding: 10px;
        border: 1px solid #000;
        border-radius: 3px;
        font-size: 14px;
        box-sizing: border-box;
    }

    .form-group input[type="checkbox"] {
        width: 10%;
        margin-right: 8px;
        cursor: pointer;
        height: 10%;
        transform: scale(2);
    }

    .form-group button {
        background: #007bff;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 3px;
        cursor: pointer;
        font-size: 16px;
        width: 100%;
    }

    .form-group button:hover {
        background: #0056b3;
    }

    {# Estilos de tareas #}
    .post-item { display: flex; justify-content: space-between; align-items: center; padding: 10px; border: 1px solid #000; margin: 5px 0; border-radius: 5px; }
    .post-text { flex: 1; }
    .post-text.completed { text-decoration: line-through; color: #999; }
    .post-actions { display: flex; gap: 10px; }
    .post-actions a, .post-actions button { padding: 5px 10px; text-decoration: none; border: none; cursor: pointer; border-radius: 3px; }
    .edit-btn { background: #007bff; color: white; }
    .toggle-btn { background: #28a745; color: white; }
    .delete-btn { background: #dc3545; color: white; }
</style>

<div class="example-wrapper">
    <h1>To Do App</h1>

    <h2>Crear tarea</h2>
    <div class="form-container">
        {{ form_start(form, {'action': path('app_tareas_create'), 'method': 'POST'}) }}
            <div class="form-group">
                {{ form_label(form.text) }}
                {{ form_widget(form.text, {attr:{'placeholder':'Tarea de ejemplo'}})}}
            </div>
            <div class="form-group checkbox-group">
                {{ form_label(form.done) }}
                {{ form_widget(form.done) }}
            </div>
            <div class="form-group">
                {{ form_widget(form.submit) }}
            </div>
        {{ form_end(form) }}
    </div>

    <h2>Tareas</h2>
    {% if posts is empty %}
        <p>No hay tareas</p>
    {% else %}
        {% for post in posts %}
            <div class="post-item">
                <div class="post-text {% if post.done %}completed{% endif %}">
                    <strong>{{ post.text }}</strong>
                </div>
                <div class="post-actions">
                    <a href="{{ path('app_tareas_edit', { id: post.id }) }}" class="edit-btn">Editar</a>
                    <a href="{{ path('app_tareas_toggle', { id: post.id }) }}" class="toggle-btn">
                        {% if post.done %}Desmarcar{% else %}Completar{% endif %}
                    </a>
                    <form method="POST" action="{{ path('app_tareas_delete', { id: post.id }) }}" style="display: inline;" onsubmit="return confirm('¿Estás seguro?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button type="submit" class="delete-btn">Eliminar</button>
                    </form>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}
