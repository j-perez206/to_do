{% block content %}
    <head>
        <meta charset="utf-8"/>
        <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <title>{% block title %}To Do App{% endblock %}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@700;800;900&amp;display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
        <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            }
            .editorial-gradient {
                background: linear-gradient(135deg, #00246a 0%, #00389a 100%);
            }
            .ghost-border {
                border-bottom: 2px solid rgba(197, 198, 205, 0.2);
            }
            .ghost-border:focus-within {
                border-bottom-color: #00246a;
            }
        </style>
        <script id="tailwind-config">
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "tertiary-fixed-dim": "#dfc299",
                            "surface-container-highest": "#e0e3e5",
                            "surface-tint": "#0053db",
                            "inverse-primary": "#b4c5ff",
                            "on-surface-variant": "#44474c",
                            "error-container": "#ffdad6",
                            "primary": "#00246a",
                            "outline-variant": "#c5c6cd",
                            "tertiary-fixed": "#fcdeb3",
                            "on-tertiary-fixed": "#281901",
                            "tertiary-container": "#503d1e",
                            "surface-bright": "#f7f9fb",
                            "primary-container": "#00389a",
                            "on-secondary-fixed": "#171c24",
                            "on-tertiary": "#ffffff",
                            "on-primary-fixed": "#00174b",
                            "surface-container-low": "#f2f4f6",
                            "on-error": "#ffffff",
                            "surface-variant": "#e0e3e5",
                            "on-surface": "#191c1e",
                            "on-error-container": "#93000a",
                            "error": "#ba1a1a",
                            "secondary-fixed": "#dee2ee",
                            "surface": "#f7f9fb",
                            "surface-container-lowest": "#ffffff",
                            "primary-fixed-dim": "#b4c5ff",
                            "on-primary": "#ffffff",
                            "on-secondary": "#ffffff",
                            "on-secondary-fixed-variant": "#424750",
                            "surface-dim": "#d8dadc",
                            "on-background": "#191c1e",
                            "on-secondary-container": "#5f656e",
                            "on-primary-container": "#8da9ff",
                            "on-tertiary-container": "#c3a881",
                            "background": "#f7f9fb",
                            "inverse-on-surface": "#eff1f3",
                            "secondary-fixed-dim": "#c2c6d1",
                            "outline": "#75777d",
                            "secondary-container": "#dee2ee",
                            "on-tertiary-fixed-variant": "#574424",
                            "secondary": "#595f68",
                            "inverse-surface": "#2d3133",
                            "surface-container-high": "#e6e8ea",
                            "primary-fixed": "#dbe1ff",
                            "tertiary": "#38270a",
                            "surface-container": "#eceef0",
                            "on-primary-fixed-variant": "#003ea8"
                        },
                        fontFamily: {
                            "headline": ["Manrope"],
                            "body": ["Inter"],
                            "label": ["Inter"]
                        },
                        borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
                    },
                },
            }
        </script>
    </head>
    <body class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed-variant">
    <!-- Main Content -->
    <main class="flex-1 ml-64">
        <!-- Featured Article -->
        <section class="py-8 my-12 px-8 bg-surface-container-lowest" id="featured">
            <div class="max-w-screen-2xl mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="flex flex-col justify-center">
                        <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tighter text-on-surface mb-6 leading-tight">
                            Algo no ha ido bien
                        </h2>
                        <p class="font-body text-lg text-on-surface-variant mb-8 leading-relaxed max-w-xl">
                            ¡Vaya! Parece que algo no ha salido según lo esperado. <br> <br> Vuelve a <a href="/" class="text-blue-500 hover:underline">Inicio</a>.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    </body>


{% endblock %}